# =============================================================================
# Trading Intelligence Hub — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# =============================================================================

# Database (Supabase)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?sslmode=require
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Supabase (used by T3 Auth)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram Bot (used by T5)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# LLM (used by T6)
ANTHROPIC_API_KEY=

# Web Search (used by T18)
TAVILY_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NOTE: Do NOT set NODE_ENV in .env.local. Next.js sets it automatically
# based on the command (next dev = development, next build/start = production).
# Manually setting it breaks dev mode and React DevTools.
